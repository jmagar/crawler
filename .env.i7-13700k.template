# Hardware-optimized environment configuration for Intel i7-13700K + 32GB DDR5 + RTX 4070
# Based on concrete research and official specifications
# 
# SECURITY WARNING: This is a template file with placeholder values.
# Use the secure configuration generator instead:
#   python scripts/generate_secure_config.py --output .env
#
# DO NOT use the placeholder passwords in production!

# ==========================================
# HARDWARE SPECIFICATIONS (Researched)
# ==========================================
# CPU: Intel i7-13700K (16 cores: 8 P-cores + 8 E-cores, 24 threads)
# Clock: 3.4GHz base, up to 5.4GHz boost
# Cache: 30MB L3, 24MB L2
# Memory: 32GB DDR5 (optimal speed: DDR5-6400 to DDR5-7200)
# GPU: NVIDIA RTX 4070 12GB VRAM
# TDP: 125W base, 253W max turbo

# ==========================================
# NEO4J CONFIGURATION - TEMPLATE VALUES
# ==========================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=GENERATE_SECURE_PASSWORD_HERE
NEO4J_URI=bolt://localhost:7687

# Neo4j Memory Settings (Based on official recommendations for 32GB)
# Heap: 8GB (same initial and max as recommended by Neo4j docs)
NEO4J_HEAP_INITIAL=8G
NEO4J_HEAP_MAX=8G
# Page Cache: 16GB (generous for database content + 20% headroom)
NEO4J_PAGECACHE=16G

# ==========================================
# PERFORMANCE TUNING (i7-13700K Optimized)
# ==========================================

# CPU Configuration (Hybrid Architecture: 8 P-cores + 8 E-cores = 24 threads)
CRAWLER_MAX_WORKERS=16                    # Leverage P-cores with hyperthreading
CRAWLER_MAX_CONCURRENT=12                 # Use ~50% of total threads
CRAWLER_MAX_CONCURRENT_QUERIES=6          # Conservative for database connections

# Memory Configuration (32GB DDR5 - High Performance)
CRAWLER_BATCH_SIZE=500                    # Larger batches for modern hardware
CRAWLER_FILE_BATCH_SIZE=300               # Process more files per batch
CRAWLER_MAX_FILE_SIZE=2097152             # 2MB max file size (generous with 32GB)
CRAWLER_PAGE_SIZE=500                     # Larger page sizes for better performance
CRAWLER_METRICS_RETENTION=10000           # Keep more metrics in memory

# Resource Management (Modern Hardware)
CRAWLER_MAX_MEMORY_USAGE_PERCENT=85       # Can use more memory safely
CRAWLER_CPU_USAGE_THRESHOLD=90            # Higher threshold for powerful CPU
CRAWLER_MONITORING_INTERVAL=1.0           # Monitor every second

# ==========================================
# ADVANCED OPTIMIZATIONS
# ==========================================

# CPU Features (Modern Intel Features)
ENABLE_AVX2_OPTIMIZATION=true             # Use AVX2 instructions
ENABLE_CPU_AFFINITY=true                  # Pin processes to specific cores
PREFER_P_CORES=true                       # Use P-cores for main workload
ENABLE_TURBO_BOOST=true                   # Allow CPU to boost to 5.4GHz
USE_MODERN_SCHEDULING=true                # Use modern CPU scheduling

# Memory Features (DDR5 Optimizations)
ENABLE_LARGE_PAGES=true                   # Use transparent huge pages
PREFER_MEMORY_OVER_CPU=true               # Leverage 32GB memory capacity
USE_AGGRESSIVE_CACHING=true               # Cache more data in memory

# Storage Features (Assumes NVMe SSD)
ASSUME_NVME_STORAGE=true                  # Optimize for NVMe performance
IO_QUEUE_DEPTH=32                         # Higher queue depth for NVMe
ENABLE_DIRECT_IO=true                     # Bypass page cache when beneficial

# ==========================================
# SYSTEM PATHS AND CONFIGURATION
# ==========================================

# Data Paths (Optimize for NVMe SSD placement)
DATA_PATH=./data
NEO4J_DATA_PATH=${DATA_PATH}/neo4j
QDRANT_DATA_PATH=${DATA_PATH}/qdrant

# Logging Configuration (Optimized for performance monitoring)
LOG_LEVEL=INFO
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# ==========================================
# DOCKER AND CONTAINER SETTINGS
# ==========================================

# Container Resource Allocation
DOCKER_NEO4J_MEMORY=24G                   # Neo4j gets most memory
DOCKER_NEO4J_CPUS=16.0                    # Can use all cores when needed
DOCKER_QDRANT_MEMORY=6G                   # Generous for vector operations
DOCKER_QDRANT_CPUS=8.0                    # Use E-cores + some P-cores

# CPU Affinity (Hybrid Architecture)
NEO4J_CPU_CORES=0-15                      # P-cores + hyperthreading
QDRANT_CPU_CORES=16-23                    # E-cores
REDIS_CPU_CORES=20-23                     # Share E-cores

# ==========================================
# GPU CONFIGURATION (RTX 4070)
# ==========================================

# GPU Settings (12GB VRAM)
ENABLE_GPU_ACCELERATION=false             # Not implemented yet, placeholder
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_LIMIT=10G                      # Reserve 2GB for system

# GPU Performance
NVIDIA_PERSISTENCE_MODE=1                 # Keep GPU initialized
NVIDIA_POWER_LIMIT=220                    # Max power for RTX 4070

# ==========================================
# PERFORMANCE MONITORING
# ==========================================

# Monitoring Features
ENABLE_PERFORMANCE_MONITORING=true        # Enable detailed performance monitoring
ENABLE_QUERY_OPTIMIZATION=true            # Enable query optimization
ENABLE_BATCH_PROCESSING=true              # Enable batch processing optimizations
ENABLE_DEBUG_METRICS=false                # Disable debug for production
ENABLE_QUERY_PROFILING=false              # Disable profiling for production
ENABLE_MEMORY_PROFILING=false             # Disable memory profiling for production

# Monitoring Intervals
PERFORMANCE_MONITORING_INTERVAL=1.0       # Monitor every second
SYSTEM_METRICS_INTERVAL=5.0               # System metrics every 5 seconds
QUERY_METRICS_RETENTION=5000              # Keep query metrics

# ==========================================
# NETWORK AND I/O OPTIMIZATION
# ==========================================

# Network Settings (High Bandwidth)
NET_CORE_RMEM_MAX=33554432                # 32MB receive buffer
NET_CORE_WMEM_MAX=33554432                # 32MB send buffer
NET_CORE_NETDEV_MAX_BACKLOG=10000         # High backlog for concurrent connections

# I/O Settings (NVMe Optimized)
FS_FILE_MAX=2097152                       # High file descriptor limit
FS_NR_OPEN=2097152                        # High open file limit

# ==========================================
# SECURITY AND AUTHENTICATION
# ==========================================

# Database Security
NEO4J_BOLT_THREAD_POOL_MIN=10             # Minimum connection pool
NEO4J_BOLT_THREAD_POOL_MAX=800            # Maximum connection pool (24 threads * ~33)

# Transaction Limits (High Concurrency)
NEO4J_TRANSACTION_TOTAL_MAX=2G            # Global transaction memory
NEO4J_TRANSACTION_MAX=128M                # Per-transaction memory
NEO4J_QUERY_GLOBAL_MAX=1G                 # Global query memory
NEO4J_QUERY_MAX=256M                      # Per-query memory

# ==========================================
# DEVELOPMENT AND DEBUGGING
# ==========================================

# Development Settings
DEVELOPMENT_MODE=false                     # Set to true for development
ENABLE_DETAILED_LOGGING=false             # Enable for troubleshooting
ENABLE_GC_LOGGING=true                     # Monitor garbage collection

# Debugging
DEBUG_CPU_AFFINITY=false                  # Debug CPU core assignments
DEBUG_MEMORY_USAGE=false                  # Debug memory allocation
DEBUG_QUERY_PERFORMANCE=false             # Debug slow queries

# ==========================================
# BACKUP AND MAINTENANCE
# ==========================================

# Backup Settings
ENABLE_AUTO_BACKUP=true                   # Enable automatic backups
BACKUP_RETENTION_DAYS=14                  # Keep 2 weeks of backups
BACKUP_COMPRESSION=true                   # Compress backup files

# Maintenance
ENABLE_AUTO_OPTIMIZATION=true             # Enable automatic query optimization
MAINTENANCE_WINDOW_HOUR=3                 # 3 AM maintenance window

# ==========================================
# EXPERIMENTAL FEATURES
# ==========================================

# Future GPU Acceleration (Placeholder)
ENABLE_CUDA_GRAPH_PROCESSING=false        # Not implemented
ENABLE_GPU_MEMORY_OPTIMIZATION=false      # Not implemented
ENABLE_TENSOR_OPERATIONS=false            # Not implemented

# Advanced CPU Features
ENABLE_NUMA_OPTIMIZATION=false            # Single socket system
ENABLE_CPU_ISOLATION=false                # Isolate CPU cores for specific tasks

# ==========================================
# VALIDATION AND SAFETY
# ==========================================

# Safety Limits
MAX_REPOSITORY_SIZE_GB=50                 # Safety limit for repository size
MAX_CONCURRENT_REPOSITORIES=3             # Limit concurrent analyses
MAX_ANALYSIS_TIME_MINUTES=120             # 2-hour timeout for safety

# Resource Monitoring Thresholds
CPU_THERMAL_THRESHOLD=80                  # Alert at 80°C
MEMORY_PRESSURE_THRESHOLD=90              # Alert at 90% memory usage
DISK_USAGE_THRESHOLD=85                   # Alert at 85% disk usage

# ==========================================
# ENVIRONMENT VALIDATION
# ==========================================

# Hardware Validation (for startup checks)
EXPECTED_CPU_CORES=16
EXPECTED_CPU_THREADS=24
EXPECTED_MEMORY_GB=32
EXPECTED_GPU_VRAM_GB=12

# Software Requirements
REQUIRED_DOCKER_VERSION=20.10.0
REQUIRED_PYTHON_VERSION=3.9.0
REQUIRED_NODE_VERSION=18.0.0